@using Numerologia.Web.Services
@inject IAuthService AuthService

<MudNavMenu>
    @if (_usuario is not null)
    {
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
            Dashboard
        </MudNavLink>
        <MudNavLink Href="/consulentes" Icon="@Icons.Material.Filled.People">
            Consulentes
        </MudNavLink>
    }
    else
    {
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
            Início
        </MudNavLink>
    }
</MudNavMenu>

@code {
    private UsuarioInfo? _usuario;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
    }
}
