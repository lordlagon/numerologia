@inject IAuthService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Numerologia Cabalística</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Início
            </NavLink>
        </div>

        @if (_usuario is not null)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="consulentes">
                    <span class="bi bi-people-fill" aria-hidden="true"></span> Consulentes
                </NavLink>
            </div>
            <div class="nav-item px-3 mt-auto">
                <span class="nav-link text-light opacity-75">@_usuario.Nome</span>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private UsuarioInfo? _usuario;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
