@using MudBlazor
@using Numerologia.Web.Helpers

<MudChip T="string"
         Size="Size.Small"
         Style="@($"background-color:{CorFavoravelHelper.ObterBackgroundCss(Cor)};color:{CorFavoravelHelper.ObterTextoCss(Cor)};border:1px solid rgba(0,0,0,.1)")">
    @Cor
</MudChip>

@code {
    [Parameter, EditorRequired] public string Cor { get; set; } = "";
}
