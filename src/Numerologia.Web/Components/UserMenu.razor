@using Numerologia.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Nav

@if (_usuario is not null)
{
    <MudMenu AnchorOrigin="Origin.BottomRight"
             TransformOrigin="Origin.TopRight"
             Dense="true">
        <ActivatorContent>
            <MudButton Color="Color.Inherit"
                       EndIcon="@Icons.Material.Filled.ArrowDropDown"
                       Class="text-capitalize">
                <MudAvatar Size="Size.Small" Class="mr-2" Style="background-color: var(--mud-palette-primary-lighten)">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                </MudAvatar>
                <MudText Typo="Typo.body2" Class="d-none d-sm-flex">@_usuario.Nome</MudText>
            </MudButton>
        </ActivatorContent>
        <ChildContent>
            <MudMenuItem Disabled="true">
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_usuario.Email</MudText>
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem Href="/perfil" Icon="@Icons.Material.Filled.Person">
                Perfil
            </MudMenuItem>
            <MudMenuItem OnClick="Sair"
                         Icon="@Icons.Material.Filled.Logout"
                         IconColor="Color.Error">
                <MudText Color="Color.Error">Sair</MudText>
            </MudMenuItem>
        </ChildContent>
    </MudMenu>
}

@code {
    private UsuarioInfo? _usuario;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
    }

    private async Task Sair()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
