@using Numerologia.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject PerfilState PerfilState
@implements IDisposable

@if (_usuario is not null)
{
    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
        <ActivatorContent>
            <MudButton Color="Color.Inherit"
                       StartIcon="@Icons.Material.Filled.AccountCircle"
                       EndIcon="@Icons.Material.Filled.ArrowDropDown">
                @(PerfilState.NomeExibicao ?? _usuario.NomeExibicao ?? _usuario.Nome)
            </MudButton>
        </ActivatorContent>
        <ChildContent>
            <MudMenuItem Disabled="true">
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_usuario.Email</MudText>
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem Href="/perfil" Icon="@Icons.Material.Filled.Person">
                Perfil
            </MudMenuItem>
            <MudMenuItem OnClick="Sair"
                         Icon="@Icons.Material.Filled.Logout"
                         IconColor="Color.Error">
                <MudText Color="Color.Error">Sair</MudText>
            </MudMenuItem>
        </ChildContent>
    </MudMenu>
}

@code {
    private UsuarioInfo? _usuario;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
        // Inicializa PerfilState com o valor atual da API para que o menu
        // exiba o nome correto mesmo antes de o usuário abrir a tela de Perfil.
        if (PerfilState.NomeExibicao is null)
            PerfilState.SilentInit(_usuario?.NomeExibicao);
        PerfilState.OnChange += AtualizarComponente;
    }

    private void AtualizarComponente() => StateHasChanged();

    private async Task Sair()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        PerfilState.OnChange -= AtualizarComponente;
    }
}
