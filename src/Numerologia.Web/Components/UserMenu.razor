@using Numerologia.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Nav

@if (_aberto)
{
    <div style="position:fixed;inset:0;z-index:999" @onclick="FecharMenu"></div>
}

@if (_usuario is not null)
{
    <div class="dropdown" style="z-index:1000;position:relative" @onclick:stopPropagation>
        <button class="btn btn-link text-dark text-decoration-none dropdown-toggle d-flex align-items-center gap-2"
                type="button"
                @onclick="ToggleMenu"
                aria-expanded="@_aberto">
            <span class="bi bi-person-circle fs-5" aria-hidden="true"></span>
            <span class="d-none d-sm-inline">@_usuario.Nome</span>
        </button>
        <ul class="dropdown-menu shadow @(_aberto ? "show" : "")" style="right:0;left:auto">
            <li>
                <span class="dropdown-item-text small text-muted">@_usuario.Email</span>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <a class="dropdown-item" href="/perfil" @onclick="FecharMenu">
                    <span class="bi bi-person me-2" aria-hidden="true"></span>Perfil
                </a>
            </li>
            <li>
                <button class="dropdown-item text-danger" @onclick="Sair">
                    <span class="bi bi-box-arrow-right me-2" aria-hidden="true"></span>Sair
                </button>
            </li>
        </ul>
    </div>
}

@code {
    private UsuarioInfo? _usuario;
    private bool _aberto;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
    }

    private void ToggleMenu() => _aberto = !_aberto;
    private void FecharMenu() => _aberto = false;

    private async Task Sair()
    {
        _aberto = false;
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
