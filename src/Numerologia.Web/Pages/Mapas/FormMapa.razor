@page "/consulentes/{ConsulenteId:int}/mapas/novo"
@using System.ComponentModel.DataAnnotations
@inject IMapasService MapasService
@inject IConsulentesService ConsulentesService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Gerar Mapa Numerológico</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Gerar Mapa Numerológico</MudText>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else
{
    <MudPaper Elevation="1" Class="pa-6" Style="max-width:480px">
        <EditForm Model="_form" OnValidSubmit="Gerar">
            <DataAnnotationsValidator />

            <MudStack Spacing="4">
                <MudTextField @bind-Value="_form.NomeUtilizado"
                              Label="Nome utilizado"
                              Required="true"
                              RequiredError="Nome utilizado é obrigatório"
                              For="() => _form.NomeUtilizado"
                              HelperText="Nome conforme certidão de nascimento (ou nome de casada, se alterado)."
                              data-testid="nome-utilizado" />

                <MudDatePicker @bind-Date="_dataNascimentoDt"
                               Label="Data de nascimento"
                               Required="true"
                               DateFormat="dd/MM/yyyy"
                               data-testid="data-nascimento" />

                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_gerando">
                        @(_gerando ? "Gerando..." : "Gerar Mapa")
                    </MudButton>
                    <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas")"
                               Variant="Variant.Outlined">
                        Cancelar
                    </MudButton>
                </MudStack>
            </MudStack>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public int ConsulenteId { get; set; }

    private readonly FormModel _form = new();
    private bool _carregando = true;
    private bool _gerando;

    private DateTime? _dataNascimentoDt
    {
        get => _form.DataNascimento == default ? null : _form.DataNascimento.ToDateTime(TimeOnly.MinValue);
        set => _form.DataNascimento = value.HasValue ? DateOnly.FromDateTime(value.Value) : DateOnly.FromDateTime(DateTime.Today);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var consulente = await ConsulentesService.ObterAsync(ConsulenteId);
            if (consulente is not null)
                _form.DataNascimento = consulente.DataNascimento;
        }
        catch { }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Gerar()
    {
        _gerando = true;

        try
        {
            await MapasService.CriarAsync(ConsulenteId, _form.NomeUtilizado!, _form.DataNascimento);
            Nav.NavigateTo($"/consulentes/{ConsulenteId}/mapas");
        }
        catch
        {
            Snackbar.Add("Erro ao gerar mapa. Verifique o nome informado.", Severity.Error);
            _gerando = false;
        }
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Nome utilizado é obrigatório")]
        public string? NomeUtilizado { get; set; }

        [Required(ErrorMessage = "Data de nascimento é obrigatória")]
        public DateOnly DataNascimento { get; set; }
    }
}
