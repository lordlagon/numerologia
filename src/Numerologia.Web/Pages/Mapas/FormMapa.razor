@page "/consulentes/{ConsulenteId:int}/mapas/novo"
@using System.ComponentModel.DataAnnotations
@inject IMapasService MapasService
@inject IConsulentesService ConsulentesService
@inject NavigationManager Nav

<PageTitle>Gerar Mapa Numerológico</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Gerar Mapa Numerológico</MudText>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" />
    <MudText>Carregando...</MudText>
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:540px">
        <EditForm Model="_form" OnValidSubmit="Gerar">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_form.NomeUtilizado"
                          Label="Nome utilizado *"
                          For="() => _form.NomeUtilizado"
                          Immediate="true"
                          HelperText="Nome conforme certidão de nascimento (ou nome de casada, se alterado)."
                          Class="mb-3"
                          data-testid="nome-utilizado" />

            <MudTextField @bind-Value="_dataNascimentoStr"
                          Label="Data de nascimento *"
                          InputType="InputType.Date"
                          Class="mb-3"
                          data-testid="data-nascimento" />

            @if (_erro is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_erro</MudAlert>
            }

            <div class="d-flex gap-2">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_gerando">
                    @(_gerando ? "Gerando..." : "Gerar Mapa")
                </MudButton>
                <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas")"
                           Variant="Variant.Outlined"
                           Color="Color.Default">Cancelar</MudButton>
            </div>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public int ConsulenteId { get; set; }

    private readonly FormModel _form = new();
    private string _dataNascimentoStr = "";
    private bool _carregando = true;
    private bool _gerando;
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var (consulente, mapas) = (
                await ConsulentesService.ObterAsync(ConsulenteId),
                await MapasService.ListarAsync(ConsulenteId));

            if (consulente is not null)
            {
                _dataNascimentoStr = consulente.DataNascimento.ToString("yyyy-MM-dd");

                if (mapas is null || mapas.Count == 0)
                    _form.NomeUtilizado = consulente.NomeCompleto;
            }
        }
        catch { }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Gerar()
    {
        _gerando = true;
        _erro = null;

        if (!DateOnly.TryParse(_dataNascimentoStr, out var dataNascimento))
        {
            _erro = "Data de nascimento é obrigatória.";
            _gerando = false;
            return;
        }

        try
        {
            await MapasService.CriarAsync(ConsulenteId, _form.NomeUtilizado!, dataNascimento);
            Nav.NavigateTo($"/consulentes/{ConsulenteId}/mapas");
        }
        catch
        {
            _erro = "Erro ao gerar mapa. Verifique o nome informado.";
            _gerando = false;
        }
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Nome utilizado é obrigatório")]
        public string? NomeUtilizado { get; set; }
    }
}
