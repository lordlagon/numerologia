@page "/consulentes/{ConsulenteId:int}/mapas/{MapaId:int}/editar"
@using System.ComponentModel.DataAnnotations
@inject IMapasService MapasService
@inject NavigationManager Nav

<PageTitle>Editar Mapa Numerológico</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Editar Mapa Numerológico</MudText>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" />
    <MudText>Carregando...</MudText>
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:540px">
        <EditForm Model="_form" OnValidSubmit="Salvar">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_form.NomeUtilizado"
                          Label="Nome utilizado *"
                          For="() => _form.NomeUtilizado"
                          Immediate="true"
                          HelperText="Nome conforme certidão de nascimento (ou nome de casada, se alterado)."
                          Class="mb-3"
                          data-testid="nome-utilizado" />

            <MudTextField @bind-Value="_dataNascimentoStr"
                          Label="Data de nascimento *"
                          InputType="InputType.Date"
                          Class="mb-3"
                          data-testid="data-nascimento" />

            @if (_erro is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_erro</MudAlert>
            }

            <div class="d-flex gap-2">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_salvando">
                    @(_salvando ? "Salvando..." : "Salvar")
                </MudButton>
                <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{MapaId}")"
                           Variant="Variant.Outlined"
                           Color="Color.Default">Cancelar</MudButton>
            </div>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public int ConsulenteId { get; set; }
    [Parameter] public int MapaId { get; set; }

    private readonly FormModel _form = new();
    private string _dataNascimentoStr = "";
    private bool _carregando = true;
    private bool _salvando;
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var mapa = await MapasService.ObterAsync(ConsulenteId, MapaId);
            if (mapa is not null)
            {
                _form.NomeUtilizado = mapa.NomeUtilizado;
                _dataNascimentoStr = mapa.DataNascimento.ToString("yyyy-MM-dd");
            }
        }
        catch
        {
            _erro = "Erro ao carregar mapa.";
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Salvar()
    {
        _salvando = true;
        _erro = null;

        if (!DateOnly.TryParse(_dataNascimentoStr, out var dataNascimento))
        {
            _erro = "Data de nascimento é obrigatória.";
            _salvando = false;
            return;
        }

        try
        {
            await MapasService.AtualizarAsync(ConsulenteId, MapaId, _form.NomeUtilizado!, dataNascimento);
            Nav.NavigateTo($"/consulentes/{ConsulenteId}/mapas/{MapaId}");
        }
        catch
        {
            _erro = "Erro ao salvar mapa.";
            _salvando = false;
        }
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Nome utilizado é obrigatório")]
        public string? NomeUtilizado { get; set; }
    }
}
