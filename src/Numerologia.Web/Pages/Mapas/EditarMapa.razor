@page "/consulentes/{ConsulenteId:int}/mapas/{MapaId:int}/editar"
@using System.ComponentModel.DataAnnotations
@inject IMapasService MapasService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Editar Mapa Numerológico</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Editar Mapa Numerológico</MudText>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else
{
    <MudPaper Elevation="1" Class="pa-6" Style="max-width:480px">
        <EditForm Model="_form" OnValidSubmit="Salvar">
            <DataAnnotationsValidator />

            <MudStack Spacing="4">
                <MudTextField @bind-Value="_form.NomeUtilizado"
                              Label="Nome utilizado"
                              Required="true"
                              RequiredError="Nome utilizado é obrigatório"
                              For="() => _form.NomeUtilizado"
                              HelperText="Nome conforme certidão de nascimento (ou nome de casada, se alterado)."
                              data-testid="nome-utilizado" />

                <MudDatePicker @bind-Date="_dataNascimentoDt"
                               Label="Data de nascimento"
                               Required="true"
                               DateFormat="dd/MM/yyyy"
                               data-testid="data-nascimento" />

                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_salvando">
                        @(_salvando ? "Salvando..." : "Salvar")
                    </MudButton>
                    <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{MapaId}")"
                               Variant="Variant.Outlined">
                        Cancelar
                    </MudButton>
                </MudStack>
            </MudStack>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public int ConsulenteId { get; set; }
    [Parameter] public int MapaId { get; set; }

    private readonly FormModel _form = new();
    private bool _carregando = true;
    private bool _salvando;

    private DateTime? _dataNascimentoDt
    {
        get => _form.DataNascimento == default ? null : _form.DataNascimento.ToDateTime(TimeOnly.MinValue);
        set => _form.DataNascimento = value.HasValue ? DateOnly.FromDateTime(value.Value) : DateOnly.FromDateTime(DateTime.Today);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var mapa = await MapasService.ObterAsync(ConsulenteId, MapaId);
            if (mapa is not null)
            {
                _form.NomeUtilizado = mapa.NomeUtilizado;
                _form.DataNascimento = mapa.DataNascimento;
            }
        }
        catch
        {
            Snackbar.Add("Erro ao carregar mapa.", Severity.Error);
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Salvar()
    {
        _salvando = true;

        try
        {
            await MapasService.AtualizarAsync(ConsulenteId, MapaId, _form.NomeUtilizado!, _form.DataNascimento);
            Nav.NavigateTo($"/consulentes/{ConsulenteId}/mapas/{MapaId}");
        }
        catch
        {
            Snackbar.Add("Erro ao salvar mapa.", Severity.Error);
            _salvando = false;
        }
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Nome utilizado é obrigatório")]
        public string? NomeUtilizado { get; set; }

        [Required(ErrorMessage = "Data de nascimento é obrigatória")]
        public DateOnly DataNascimento { get; set; }
    }
}
