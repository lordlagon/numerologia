@page "/consulentes/{ConsulenteId:int}/mapas/{MapaId:int}"
@using Numerologia.Web.Components
@using Numerologia.Core.Services
@inject IMapasService MapasService
@inject ICalculosPessoaisService PessoaisService
@inject NavigationManager Nav

<PageTitle>Gráfico Numerológico</PageTitle>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else if (_erro is not null)
{
    <MudAlert Severity="Severity.Error">@_erro</MudAlert>
}
else if (_mapa is not null)
{
    var somaMotivacao  = _mapa.SomaMotivacao;
    var somaImpressao  = _mapa.SomaImpressao;
    var somaExpressao  = _mapa.SomaExpressao;

    // F2.7 — anos dos Ciclos de Vida
    var anoNasc      = _mapa.DataNascimento.Year;
    var anoFimCiclo1 = anoNasc + _mapa.FimCiclo1Idade;
    var anoFimCiclo2 = anoNasc + _mapa.FimCiclo2Idade;

    // F2.8 — anos dos Momentos Decisivos (livro pág. 196)
    var anoFimMD1 = anoFimCiclo1;
    var anoFimMD2 = anoFimMD1 + 9;
    var anoFimMD3 = anoFimMD2 + 9;

    <div class="grafico-numerologico">

        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2 fw-bold">GRÁFICO NUMEROLÓGICO</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-4">
            @_mapa.NomeUtilizado — @_mapa.DataNascimento.ToString("dd/MM/yyyy")
        </MudText>

        <!-- ── GRADE DE LETRAS ─────────────────────────────────────────── -->
        <MudPaper Class="mb-3 pa-2">
            <div class="grade-letras">
                <table class="grade-table">
                    <tbody>
                        <tr>
                            <td class="grade-label">Vogais</td>
                            @foreach (var e in _mapa.GradeLetras)
                            {
                                <td class="grade-cell @(e.Tipo == TipoLetraDto.Espaco ? "grade-espaco" : "")">
                                    @if (e.Tipo == TipoLetraDto.Vogal)
                                    { <span class="fw-bold">@e.ValorCabalistico</span> }
                                </td>
                            }
                            <td class="grade-label-right">Nº de Motivação</td>
                            <td class="grade-resultado fw-bold" data-testid="motivacao">@somaMotivacao => @_mapa.NumeroMotivacao</td>
                        </tr>
                        <tr>
                            <td class="grade-label">Nome</td>
                            @foreach (var e in _mapa.GradeLetras)
                            {
                                <td class="grade-cell" data-testid="celula-letra">
                                    @if (e.Tipo != TipoLetraDto.Espaco)
                                    { <span>@e.Letra</span> }
                                </td>
                            }
                            <td></td><td></td>
                        </tr>
                        <tr>
                            <td class="grade-label">Consoante</td>
                            @foreach (var e in _mapa.GradeLetras)
                            {
                                <td class="grade-cell">
                                    @if (e.Tipo == TipoLetraDto.Consoante)
                                    { <span>@e.ValorCabalistico</span> }
                                </td>
                            }
                            <td class="grade-label-right">Nº de Impressão</td>
                            <td class="grade-resultado fw-bold" data-testid="impressao">@somaImpressao => @_mapa.NumeroImpressao</td>
                        </tr>
                        <tr>
                            <td class="grade-label">TOTAL</td>
                            @foreach (var e in _mapa.GradeLetras)
                            {
                                <td class="grade-cell">
                                    @if (e.Tipo != TipoLetraDto.Espaco)
                                    { <span>@e.ValorCabalistico</span> }
                                </td>
                            }
                            <td class="grade-label-right">Nº de Expressão</td>
                            <td class="grade-resultado fw-bold" data-testid="expressao">@somaExpressao => @_mapa.NumeroExpressao</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </MudPaper>

        <!-- ── TRÊS COLUNAS: Fig. A | Central | Direita ──────────────── -->
        <div class="d-flex flex-wrap gap-3 align-items-start">

            <!-- ── COLUNA ESQUERDA: Fig. A ─────────────────────────────── -->
            <MudPaper Class="pa-2">
                <div class="text-center fw-bold mb-1">Fig. "A"</div>
                <table class="figura-table">
                    <tbody>
                        @foreach (var kv in _mapa.FiguraA.OrderBy(x => int.Parse(x.Key)))
                        {
                            <tr>
                                <td class="fw-bold">@kv.Key</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="text-center mt-1" style="font-size:0.7rem">Total de Letras<br/>em Cada Número</div>
            </MudPaper>

            <!-- ── COLUNA CENTRAL ─────────────────────────────────────── -->
            <div class="flex-grow-1 d-flex flex-wrap gap-2">

                <!-- Fig. B — Lições Cármicas -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Fig. B</div>
                    <div class="d-flex gap-1 flex-wrap">
                        @foreach (var n in _mapa.LicoesCarmicas)
                        {
                            <span class="num-badge num-badge-warning">@n</span>
                        }
                        @if (!_mapa.LicoesCarmicas.Any())
                        {
                            <span class="text-muted">—</span>
                        }
                    </div>
                    <div class="text-center mt-1" style="font-size:0.7rem">Lições Cármicas</div>
                </MudPaper>

                <!-- Fig. C — Tendências Ocultas -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Fig. C</div>
                    <div class="d-flex gap-1 flex-wrap">
                        @foreach (var n in _mapa.TendenciasOcultas)
                        {
                            <span class="num-badge num-badge-info">@n</span>
                        }
                    </div>
                    <div class="text-center mt-1" style="font-size:0.7rem">Tendências Ocultas</div>
                </MudPaper>

                <!-- Fig. D -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Fig. D</div>
                    <table class="figura-table">
                        <tbody>
                            <tr>
                                <td>Resp. Subconsciente</td>
                                <td class="fw-bold">@_mapa.RespostaSubconsciente</td>
                            </tr>
                            <tr>
                                <td>Mês</td>
                                <td class="fw-bold" data-testid="data-mes">@_mapa.DataNascimento.Month.ToString("00") => @_mapa.MesNascimentoReduzido</td>
                            </tr>
                            <tr>
                                <td>Dia</td>
                                <td class="fw-bold" data-testid="data-dia">@_mapa.DataNascimento.Day => @_mapa.DiaNascimentoReduzido</td>
                            </tr>
                            <tr>
                                <td>Ano do Nascimento</td>
                                <td class="fw-bold" data-testid="data-ano">@_mapa.DataNascimento.Year => @_mapa.AnoNascimentoReduzido</td>
                            </tr>
                        </tbody>
                    </table>
                </MudPaper>

                <!-- Fig. E -->
                <MudPaper Class="pa-2 w-100">
                    <div class="fw-bold text-center mb-1">Fig. E</div>
                    <div class="d-flex gap-3 flex-wrap align-items-start">
                        <div class="text-center">
                            <div style="font-size:0.7rem">Dívidas Cármicas</div>
                            <div class="d-flex gap-1">
                                @foreach (var n in _mapa.DividasCarmicas)
                                {
                                    <span class="num-badge num-badge-error">@n</span>
                                }
                                @if (!_mapa.DividasCarmicas.Any())
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                        <div class="text-center">
                            <div style="font-size:0.7rem">Nº de Destino</div>
                            <div class="fw-bold fs-5" data-testid="destino">@_mapa.NumeroDestino</div>
                        </div>
                        <div class="text-center">
                            <div style="font-size:0.7rem">Missão</div>
                            <div class="fw-bold fs-5">@_mapa.Missao</div>
                        </div>
                        <div class="text-center">
                            <div style="font-size:0.7rem">Ano Pessoal</div>
                            <div class="fw-bold fs-5" data-testid="ano-pessoal">@(_pessoal?.AnoPessoal.ToString() ?? "—")</div>
                        </div>
                        @if (_pessoal is not null)
                        {
                            <div class="text-center">
                                <div style="font-size:0.7rem">Mês Pessoal</div>
                                <div class="fw-bold fs-5">@_pessoal.MesPessoal</div>
                            </div>
                            <div class="text-center">
                                <div style="font-size:0.7rem">Dia Pessoal</div>
                                <div class="fw-bold fs-5">@_pessoal.DiaPessoal</div>
                            </div>
                        }
                    </div>
                </MudPaper>

                <!-- Dias do Mês Favoráveis -->
                <MudPaper Class="pa-2 w-100">
                    <div class="d-flex gap-1 flex-wrap align-items-center">
                        <span style="font-size:0.8rem" class="me-2">Dias do Mês Favoráveis</span>
                        @foreach (var n in _mapa.DiasMesFavoraveis)
                        {
                            <span class="num-badge num-badge-success">@n</span>
                        }
                    </div>
                </MudPaper>

                <!-- Números Harmônicos + Relação Intervalores -->
                <MudPaper Class="pa-2">
                    <div style="font-size:0.7rem" class="mb-1">Números Harmônicos</div>
                    <div class="d-flex gap-1 flex-wrap">
                        @foreach (var n in _mapa.NumerosHarmonicos)
                        {
                            <span class="num-badge num-badge-primary">@n</span>
                        }
                    </div>
                </MudPaper>
                <MudPaper Class="pa-2 text-center">
                    <div style="font-size:0.7rem">Relação Intervalores</div>
                    <div class="fw-bold fs-5">@_mapa.RelacaoIntervalores</div>
                </MudPaper>

                <!-- Cores Favoráveis -->
                <MudPaper Class="pa-2 w-100">
                    <div style="font-size:0.7rem" class="mb-1">Cores Favoráveis</div>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var cor in _mapa.CoresFavoraveis)
                        {
                            <BadgeCor Cor="@cor" />
                        }
                    </div>
                </MudPaper>

            </div>

            <!-- ── COLUNA DIREITA: Fig. F, G, H + Harmonia ───────────── -->
            <div class="d-flex flex-column gap-2">

                <!-- Fig. F — Ciclos de Vida -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Fig. F — Ciclos de Vida</div>
                    <table class="figura-table">
                        <tbody>
                            <tr>
                                <td>1º Ciclo</td>
                                <td class="fw-bold" data-testid="ciclo1">@_mapa.CicloVida1</td>
                                <td style="font-size:0.7rem" data-testid="ciclo1-periodo">de @anoNasc até @anoFimCiclo1</td>
                                <td style="font-size:0.7rem">até @_mapa.FimCiclo1Idade anos</td>
                            </tr>
                            <tr>
                                <td>2º Ciclo</td>
                                <td class="fw-bold" data-testid="ciclo2">@_mapa.CicloVida2</td>
                                <td style="font-size:0.7rem" data-testid="ciclo2-periodo">de @anoFimCiclo1 até @anoFimCiclo2</td>
                                <td style="font-size:0.7rem">até @_mapa.FimCiclo2Idade anos</td>
                            </tr>
                            <tr>
                                <td>3º Ciclo</td>
                                <td class="fw-bold" data-testid="ciclo3">@_mapa.CicloVida3</td>
                                <td style="font-size:0.7rem" data-testid="ciclo3-periodo">de @anoFimCiclo2 em diante</td>
                                <td style="font-size:0.7rem">em diante</td>
                            </tr>
                        </tbody>
                    </table>
                </MudPaper>

                <!-- Fig. H — Desafios -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Fig. H — Desafios</div>
                    <table class="figura-table">
                        <tbody>
                            <tr>
                                <td>Primeiro</td>
                                <td class="fw-bold" data-testid="desafio1">@_mapa.Desafio1</td>
                            </tr>
                            <tr>
                                <td>Segundo</td>
                                <td class="fw-bold" data-testid="desafio2">@_mapa.Desafio2</td>
                            </tr>
                            <tr>
                                <td>Principal</td>
                                <td class="fw-bold" data-testid="desafio-principal">@_mapa.DesafioPrincipal</td>
                            </tr>
                        </tbody>
                    </table>
                </MudPaper>

                <!-- Fig. G — Momentos Decisivos -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Fig. G — Momentos Decisivos</div>
                    <table class="figura-table">
                        <tbody>
                            <tr>
                                <td>1º</td>
                                <td class="fw-bold">@_mapa.MomentoDecisivo1</td>
                                <td style="font-size:0.7rem" data-testid="md1-periodo">de @anoNasc até @anoFimMD1</td>
                            </tr>
                            <tr>
                                <td>2º</td>
                                <td class="fw-bold">@_mapa.MomentoDecisivo2</td>
                                <td style="font-size:0.7rem" data-testid="md2-periodo">de @anoFimMD1 até @anoFimMD2</td>
                            </tr>
                            <tr>
                                <td>3º</td>
                                <td class="fw-bold">@_mapa.MomentoDecisivo3</td>
                                <td style="font-size:0.7rem" data-testid="md3-periodo">de @anoFimMD2 até @anoFimMD3</td>
                            </tr>
                            <tr>
                                <td>4º</td>
                                <td class="fw-bold">@_mapa.MomentoDecisivo4</td>
                                <td style="font-size:0.7rem" data-testid="md4-periodo">de @anoFimMD3 em diante</td>
                            </tr>
                        </tbody>
                    </table>
                </MudPaper>

                <!-- Harmonia Conjugal -->
                <MudPaper Class="pa-2">
                    <div class="fw-bold text-center mb-1">Harmonia Conjugal</div>
                    <table class="figura-table">
                        <tbody>
                            <tr>
                                <td>Vibra com</td>
                                <td class="fw-bold text-center" data-testid="harmonia-vibra-com">@_mapa.HarmoniaVibraCom</td>
                            </tr>
                            <tr>
                                <td>Atrai</td>
                                <td>@string.Join(", ", _mapa.HarmoniaAtrai)</td>
                            </tr>
                            <tr>
                                <td>É oposto a</td>
                                <td>@string.Join(", ", _mapa.HarmoniaEOpostoA)
                                    @if (_mapa.HarmoniaProfundamenteOpostoA.Any())
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error" Inline="true">
                                            (@string.Join(", ", _mapa.HarmoniaProfundamenteOpostoA) prof.)
                                        </MudText>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td>É passivo</td>
                                <td>@string.Join(", ", _mapa.HarmoniaEPassivoEm)</td>
                            </tr>
                        </tbody>
                    </table>
                </MudPaper>

            </div>

        </div><!-- /três colunas -->

    </div><!-- /grafico-numerologico -->

    <!-- ── Interpretações ─────────────────────────────────────────────── -->
    <MudExpansionPanel Text="Interpretações" Class="mt-4" KeepContentAlive="true">
        <MudGrid Spacing="3">

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Nº de Motivação — @_mapa.NumeroMotivacao</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Motivacao(_mapa.NumeroMotivacao)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Nº de Impressão — @_mapa.NumeroImpressao</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Impressao(_mapa.NumeroImpressao)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Nº de Destino — @_mapa.NumeroDestino</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Destino(_mapa.NumeroDestino)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Missão — @_mapa.Missao</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Missao(_mapa.Missao)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Dia do Nascimento — @_mapa.DiaNascimentoReduzido</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.DiaNascimento(_mapa.DiaNascimentoReduzido)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Resposta Subconsciente — @_mapa.RespostaSubconsciente</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.RespostaSubconsciente(_mapa.RespostaSubconsciente)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @if (_pessoal is not null)
            {
                var intAP = InterpretacoesNumerologicas.AnoPessoal(_pessoal.AnoPessoal);
                @if (!string.IsNullOrEmpty(intAP))
                {
                    <MudItem xs="12" sm="6">
                        <MudCard>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2">Ano Pessoal — @_pessoal.AnoPessoal</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@intAP</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            }

            @if (_mapa.LicoesCarmicas.Any())
            {
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2">Lições Cármicas</MudText>
                            <ul class="mb-0">
                                @foreach (var n in _mapa.LicoesCarmicas)
                                {
                                    <li><strong>@n</strong> — @InterpretacoesNumerologicas.LicaoCarmica(n)</li>
                                }
                            </ul>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @if (_mapa.TendenciasOcultas.Any())
            {
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2">Tendências Ocultas</MudText>
                            <ul class="mb-0">
                                @foreach (var n in _mapa.TendenciasOcultas)
                                {
                                    <li><strong>@n</strong> — @InterpretacoesNumerologicas.TendenciaOculta(n)</li>
                                }
                            </ul>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @if (_mapa.DividasCarmicas.Any())
            {
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle2">Dívidas Cármicas</MudText>
                            <ul class="mb-0">
                                @foreach (var n in _mapa.DividasCarmicas)
                                {
                                    <li><strong>@n</strong> — @InterpretacoesNumerologicas.DividaCarmica(n)</li>
                                }
                            </ul>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            <MudItem xs="12" sm="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2">Relação Intervalores — @_mapa.RelacaoIntervalores</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" data-testid="interp-intervalores">@InterpretacoesNumerologicas.RelacaoIntervalores(_mapa.RelacaoIntervalores)</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>
    </MudExpansionPanel>

    <MudStack Row="true" Class="mt-3 mb-5" Spacing="2">
        <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{MapaId}/editar")"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Edit">
            Editar
        </MudButton>
        <MudButton Href="@($"/api/consulentes/{ConsulenteId}/mapas/{MapaId}/pdf")"
                   Target="_blank"
                   Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                   data-testid="btn-baixar-pdf">
            Baixar PDF
        </MudButton>
        <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas")"
                   Variant="Variant.Text"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Voltar
        </MudButton>
    </MudStack>
}

@code {
    [Parameter] public int ConsulenteId { get; set; }
    [Parameter] public int MapaId { get; set; }

    private MapaDetalheDto? _mapa;
    private ResultadoPessoalDto? _pessoal;
    private bool _carregando = true;
    private string? _erro;

    protected override async Task OnParametersSetAsync()
    {
        _carregando = true;
        try
        {
            _mapa = await MapasService.ObterAsync(ConsulenteId, MapaId);
            if (_mapa is null)
            {
                _erro = "Mapa não encontrado.";
                return;
            }

            _pessoal = await PessoaisService.ObterAsync(
                _mapa.DataNascimento.Day,
                _mapa.DataNascimento.Month);
        }
        catch
        {
            _erro = "Erro ao carregar o gráfico.";
        }
        finally
        {
            _carregando = false;
        }
    }
}
