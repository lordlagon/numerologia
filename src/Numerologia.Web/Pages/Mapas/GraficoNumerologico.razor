@page "/consulentes/{ConsulenteId:int}/mapas/{MapaId:int}"
@using Numerologia.Web.Components
@using Numerologia.Core.Services
@inject IMapasService MapasService
@inject ICalculosPessoaisService PessoaisService
@inject NavigationManager Nav

<PageTitle>Gráfico Numerológico</PageTitle>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_erro is not null)
{
    <MudAlert Severity="Severity.Error">@_erro</MudAlert>
}
else if (_mapa is not null)
{
    var anoNasc      = _mapa.DataNascimento.Year;
    var anoFimCiclo1 = anoNasc + _mapa.FimCiclo1Idade;
    var anoFimCiclo2 = anoNasc + _mapa.FimCiclo2Idade;
    var anoFimMD1    = anoFimCiclo1;
    var anoFimMD2    = anoFimMD1 + 9;
    var anoFimMD3    = anoFimMD2 + 9;

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-1 fw-bold">GRÁFICO NUMEROLÓGICO</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-4">
        @_mapa.NomeUtilizado — @_mapa.DataNascimento.ToString("dd/MM/yyyy")
    </MudText>

    <!-- ── GRADE DE LETRAS — HTML/CSS flex puro ──────────────────────────── -->
    <MudPaper Elevation="2" Class="mb-3 pa-2 overflow-auto">
        <div style="display:flex;flex-direction:column;gap:2px;font-size:0.78rem">

            @foreach (var (rotulo, tipo, labelDir, valorDir, testId) in new[]
            {
                ("Vogais",    TipoLetraDto.Vogal,      "Nº de Motivação",  $"{_mapa.SomaMotivacao} => {_mapa.NumeroMotivacao}",  "motivacao"),
                ("Nome",      TipoLetraDto.Espaco,      "",                 "",                                                   ""),
                ("Consoante", TipoLetraDto.Consoante,  "Nº de Impressão",  $"{_mapa.SomaImpressao} => {_mapa.NumeroImpressao}",  "impressao"),
                ("TOTAL",     (TipoLetraDto)(-1),       "Nº de Expressão",  $"{_mapa.SomaExpressao} => {_mapa.NumeroExpressao}",  "expressao"),
            })
            {
                <div style="display:flex;align-items:stretch;gap:2px">
                    <div style="width:70px;flex-shrink:0;padding:2px 6px;background:#f3e5f5;font-weight:bold;font-size:0.75rem;text-align:right;white-space:nowrap;display:flex;align-items:center;justify-content:flex-end">
                        @rotulo
                    </div>
                    <div style="flex:1;display:flex;gap:2px">
                        @foreach (var e in _mapa.GradeLetras)
                        {
                            var valor = rotulo == "Vogais"    ? (e.Tipo == TipoLetraDto.Vogal     ? e.ValorCabalistico.ToString() : "")
                                      : rotulo == "Nome"      ? (e.Tipo != TipoLetraDto.Espaco    ? e.Letra.ToString()             : "")
                                      : rotulo == "Consoante" ? (e.Tipo == TipoLetraDto.Consoante ? e.ValorCabalistico.ToString() : "")
                                      :                         (e.Tipo != TipoLetraDto.Espaco    ? e.ValorCabalistico.ToString() : "");
                            var bgColor = e.Tipo == TipoLetraDto.Espaco ? "#ede7f6" : "white";
                            if (rotulo == "Nome")
                            {
                                <div data-testid="celula-letra"
                                     style="@($"flex:1;min-width:0;height:28px;display:flex;align-items:center;justify-content:center;font-size:0.82rem;background:{bgColor};border:1px solid #ddd")">
                                    @valor
                                </div>
                            }
                            else
                            {
                                <div style="@($"flex:1;min-width:0;height:28px;display:flex;align-items:center;justify-content:center;font-size:0.82rem;background:{bgColor};border:1px solid #ddd")">
                                    @valor
                                </div>
                            }
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(labelDir))
                    {
                        <div style="width:120px;flex-shrink:0;padding:2px 6px;background:#f3e5f5;font-size:0.72rem;white-space:nowrap;display:flex;align-items:center;margin-left:4px">
                            @labelDir
                        </div>
                        <div data-testid="@testId"
                             style="width:90px;flex-shrink:0;padding:2px 6px;font-weight:bold;font-size:0.72rem;white-space:nowrap;background:#f3e5f5;display:flex;align-items:center">
                            @valorDir
                        </div>
                    }
                    else
                    {
                        <div style="width:214px;flex-shrink:0"></div>
                    }
                </div>
            }
        </div>
    </MudPaper>

    <!-- ── FIGURAS ──────────────────────────────────────────────────────── -->
    <MudGrid Spacing="2">

        <!-- Fig. A -->
        <MudItem xs="12" sm="2">
            <MudCard Elevation="2"><MudCardContent Class="pa-2">
                <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Fig. "A"</MudText>
                @foreach (var kv in _mapa.FiguraA.OrderBy(x => int.Parse(x.Key)))
                {
                    <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid #eee;font-size:0.78rem;align-items:center">
                        <div style="background:#f3e5f5;font-weight:bold;text-align:center;padding:2px 4px">@kv.Key</div>
                        <div style="text-align:center;padding:2px 4px">@kv.Value</div>
                    </div>
                }
                <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-1">Total de Letras<br />em Cada Número</MudText>
            </MudCardContent></MudCard>
        </MudItem>

        <!-- Coluna central -->
        <MudItem xs="12" sm="7">
            <MudGrid Spacing="2">

                <!-- Fig. B — Lições Cármicas -->
                <MudItem xs="6" sm="4">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.subtitle2" Align="Align.Center">Fig. B — Lições Cármicas</MudText>
                        <div class="d-flex flex-wrap gap-1 mt-1 justify-center">
                            @foreach (var n in _mapa.LicoesCarmicas)
                            { <MudChip T="string" Color="Color.Warning" Size="Size.Small">@n</MudChip> }
                            @if (!_mapa.LicoesCarmicas.Any()) { <MudText Typo="Typo.body2">—</MudText> }
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Fig. C — Tendências Ocultas -->
                <MudItem xs="6" sm="4">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.subtitle2" Align="Align.Center">Fig. C — Tendências Ocultas</MudText>
                        <div class="d-flex flex-wrap gap-1 mt-1 justify-center">
                            @foreach (var n in _mapa.TendenciasOcultas)
                            { <MudChip T="string" Color="Color.Info" Size="Size.Small">@n</MudChip> }
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Fig. D — Resp. Subconsciente -->
                <MudItem xs="6" sm="4">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.subtitle2" Align="Align.Center">Fig. D</MudText>
                        <div class="d-flex flex-wrap gap-1 mt-1 justify-center">
                            <MudText Typo="Typo.caption">Resp. Subconsciente</MudText>
                        </div>
                        <div class="d-flex justify-center mt-1">
                            <MudChip T="string" Color="Color.Tertiary" Size="Size.Small">@_mapa.RespostaSubconsciente</MudChip>
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Data Natal -->
                <MudItem xs="6" sm="4">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Data Natal</MudText>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;font-size:0.78rem">
                            <div>Dia</div><div class="fw-bold" data-testid="data-dia">@_mapa.DataNascimento.Day</div>
                            <div>Mês</div><div class="fw-bold" data-testid="data-mes">@_mapa.DataNascimento.Month</div>
                            <div>Ano</div><div class="fw-bold" data-testid="data-ano">@_mapa.DataNascimento.Year</div>
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Fig. E -->
                <MudItem xs="12">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Fig. E</MudText>
                        <div class="d-flex flex-wrap gap-3 align-start">
                            <div class="text-center">
                                <MudText Typo="Typo.caption">Dívidas Cármicas</MudText>
                                <div class="d-flex gap-1 justify-center mt-1">
                                    @foreach (var n in _mapa.DividasCarmicas)
                                    { <MudChip T="string" Color="Color.Error" Size="Size.Small">@n</MudChip> }
                                    @if (!_mapa.DividasCarmicas.Any()) { <MudText Typo="Typo.body2">—</MudText> }
                                </div>
                            </div>
                            <div class="text-center">
                                <MudText Typo="Typo.caption">Nº de Destino</MudText>
                                <div class="d-flex justify-center mt-1">
                                    <MudChip T="string" Color="Color.Primary" Size="Size.Small" data-testid="destino">@_mapa.NumeroDestino</MudChip>
                                </div>
                            </div>
                            <div class="text-center">
                                <MudText Typo="Typo.caption">Missão</MudText>
                                <div class="d-flex justify-center mt-1">
                                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@_mapa.Missao</MudChip>
                                </div>
                            </div>
                            <div class="text-center">
                                <MudText Typo="Typo.caption">Ano Pessoal</MudText>
                                <div class="d-flex justify-center mt-1">
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" data-testid="ano-pessoal">@(_pessoal?.AnoPessoal.ToString() ?? "—")</MudChip>
                                </div>
                            </div>
                            @if (_pessoal is not null)
                            {
                                <div class="text-center">
                                    <MudText Typo="Typo.caption">Mês Pessoal</MudText>
                                    <div class="d-flex justify-center mt-1">
                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@_pessoal.MesPessoal</MudChip>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <MudText Typo="Typo.caption">Dia Pessoal</MudText>
                                    <div class="d-flex justify-center mt-1">
                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@_pessoal.DiaPessoal</MudChip>
                                    </div>
                                </div>
                            }
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Dias do Mês Favoráveis -->
                <MudItem xs="12">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.body2" Class="mb-1"><strong>Dias do Mês Favoráveis</strong></MudText>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var n in _mapa.DiasMesFavoraveis)
                            { <MudChip T="string" Color="Color.Success" Size="Size.Small">@n</MudChip> }
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Números Harmônicos + Relação Intervalores -->
                <MudItem xs="6">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.caption" Class="mb-1">Números Harmônicos</MudText>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var n in _mapa.NumerosHarmonicos)
                            { <MudChip T="string" Color="Color.Primary" Size="Size.Small">@n</MudChip> }
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="6">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2 text-center">
                        <MudText Typo="Typo.caption">Relação Intervalores</MudText>
                        <MudText Typo="Typo.h6" Class="mt-1">@_mapa.RelacaoIntervalores</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                <!-- Cores Favoráveis -->
                <MudItem xs="12">
                    <MudCard Elevation="2"><MudCardContent Class="pa-2">
                        <MudText Typo="Typo.caption" Class="mb-1">Cores Favoráveis</MudText>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var cor in _mapa.CoresFavoraveis)
                            {
                                <BadgeCor Cor="@cor" />
                            }
                        </div>
                    </MudCardContent></MudCard>
                </MudItem>

            </MudGrid>
        </MudItem>

        <!-- Coluna direita: Fig. F, G, H + Harmonia -->
        <MudItem xs="12" sm="3">
            <div class="d-flex flex-column gap-2">

                <!-- Fig. F — Ciclos de Vida -->
                <MudCard Elevation="2"><MudCardContent Class="pa-2">
                    <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Fig. F — Ciclos de Vida</MudText>
                    @foreach (var (ciclo, valor, de, ate, testIdVal, testIdPer) in new[]
                    {
                        ("1º", _mapa.CicloVida1, anoNasc,      anoFimCiclo1, "ciclo1", "ciclo1-periodo"),
                        ("2º", _mapa.CicloVida2, anoFimCiclo1, anoFimCiclo2, "ciclo2", "ciclo2-periodo"),
                        ("3º", _mapa.CicloVida3, anoFimCiclo2, 0,            "ciclo3", "ciclo3-periodo"),
                    })
                    {
                        <div class="d-flex justify-space-between align-center px-1" style="border-bottom:1px solid #eee;font-size:0.75rem">
                            <span>@ciclo Ciclo</span>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" data-testid="@testIdVal">@valor</MudChip>
                            <span style="color:#666" data-testid="@testIdPer">@(ate > 0 ? $"{de}–{ate}" : $"{de}→")</span>
                        </div>
                    }
                </MudCardContent></MudCard>

                <!-- Fig. H — Desafios -->
                <MudCard Elevation="2"><MudCardContent Class="pa-2">
                    <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Fig. H — Desafios</MudText>
                    @foreach (var (nome, valor, testIdVal) in new[]
                    {
                        ("Primeiro",  _mapa.Desafio1,        "desafio1"),
                        ("Segundo",   _mapa.Desafio2,        "desafio2"),
                        ("Principal", _mapa.DesafioPrincipal,"desafio-principal"),
                    })
                    {
                        <div class="d-flex justify-space-between align-center px-1" style="border-bottom:1px solid #eee;font-size:0.75rem">
                            <span>@nome</span>
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" data-testid="@testIdVal">@valor</MudChip>
                        </div>
                    }
                </MudCardContent></MudCard>

                <!-- Fig. G — Momentos Decisivos -->
                <MudCard Elevation="2"><MudCardContent Class="pa-2">
                    <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Fig. G — Momentos Decisivos</MudText>
                    @foreach (var (ord, valor, de, ate, testIdPer) in new[]
                    {
                        ("1º", _mapa.MomentoDecisivo1, anoNasc,   anoFimMD1, "md1-periodo"),
                        ("2º", _mapa.MomentoDecisivo2, anoFimMD1, anoFimMD2, "md2-periodo"),
                        ("3º", _mapa.MomentoDecisivo3, anoFimMD2, anoFimMD3, "md3-periodo"),
                        ("4º", _mapa.MomentoDecisivo4, anoFimMD3, 0,         "md4-periodo"),
                    })
                    {
                        <div class="d-flex justify-space-between align-center px-1" style="border-bottom:1px solid #eee;font-size:0.75rem">
                            <span>@ord</span>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small">@valor</MudChip>
                            <span style="color:#666" data-testid="@testIdPer">@(ate > 0 ? $"{de}–{ate}" : $"{de}→")</span>
                        </div>
                    }
                </MudCardContent></MudCard>

                <!-- Harmonia Conjugal -->
                <MudCard Elevation="2"><MudCardContent Class="pa-2">
                    <MudText Typo="Typo.subtitle2" Align="Align.Center" Class="mb-1">Harmonia Conjugal</MudText>
                    <div style="font-size:0.75rem">
                        <div class="d-flex align-center gap-1 mb-1">
                            <span>Vibra com:</span>
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" data-testid="harmonia-vibra-com">@_mapa.HarmoniaVibraCom</MudChip>
                        </div>
                        <div class="d-flex flex-wrap align-center gap-1 mb-1">
                            <span>Atrai:</span>
                            @foreach (var n in _mapa.HarmoniaAtrai)
                            { <MudChip T="string" Color="Color.Success" Size="Size.Small">@n</MudChip> }
                        </div>
                        <div class="d-flex flex-wrap align-center gap-1 mb-1">
                            <span>É oposto a:</span>
                            @foreach (var n in _mapa.HarmoniaEOpostoA)
                            { <MudChip T="string" Color="Color.Error" Size="Size.Small">@n</MudChip> }
                            @foreach (var n in _mapa.HarmoniaProfundamenteOpostoA)
                            { <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Outlined">@n prof.</MudChip> }
                        </div>
                        <div class="d-flex flex-wrap align-center gap-1">
                            <span>É passivo:</span>
                            @foreach (var n in _mapa.HarmoniaEPassivoEm)
                            { <MudChip T="string" Color="Color.Default" Size="Size.Small">@n</MudChip> }
                        </div>
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">Número base: <strong data-testid="numero-amor">@_mapa.Missao</strong></MudText>
                </MudCardContent></MudCard>

            </div>
        </MudItem>

    </MudGrid>

    <!-- ── Interpretações ──────────────────────────────────────────────── -->
    <MudExpansionPanels Class="mt-4">
        <MudExpansionPanel Text="Interpretações">

            <MudGrid Spacing="3">

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2">Nº de Motivação — @_mapa.NumeroMotivacao</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Motivacao(_mapa.NumeroMotivacao)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2">Nº de Impressão — @_mapa.NumeroImpressao</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Impressao(_mapa.NumeroImpressao)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2">Nº de Destino — @_mapa.NumeroDestino</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Destino(_mapa.NumeroDestino)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2">Missão — @_mapa.Missao</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.Missao(_mapa.Missao)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2" data-testid="interp-dia-nascimento-titulo">Dia do Nascimento — @_mapa.DataNascimento.Day</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" data-testid="interp-dia-nascimento">@InterpretacoesNumerologicas.DiaNascimento(_mapa.DataNascimento.Day)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2">Resposta Subconsciente — @_mapa.RespostaSubconsciente</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@InterpretacoesNumerologicas.RespostaSubconsciente(_mapa.RespostaSubconsciente)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

                @if (_pessoal is not null)
                {
                    var intAP = InterpretacoesNumerologicas.AnoPessoal(_pessoal.AnoPessoal);
                    @if (!string.IsNullOrEmpty(intAP))
                    {
                        <MudItem xs="12" sm="6">
                            <MudCard Elevation="1"><MudCardContent>
                                <MudText Typo="Typo.subtitle2">Ano Pessoal — @_pessoal.AnoPessoal</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@intAP</MudText>
                            </MudCardContent></MudCard>
                        </MudItem>
                    }
                }

                @if (_mapa.LicoesCarmicas.Any())
                {
                    <MudItem xs="12">
                        <MudCard Elevation="1"><MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Lições Cármicas</MudText>
                            <ul class="mb-0">
                                @foreach (var n in _mapa.LicoesCarmicas)
                                {
                                    <li><strong>@n</strong> — @InterpretacoesNumerologicas.LicaoCarmica(n)</li>
                                }
                            </ul>
                        </MudCardContent></MudCard>
                    </MudItem>
                }

                @if (_mapa.TendenciasOcultas.Any())
                {
                    <MudItem xs="12">
                        <MudCard Elevation="1"><MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Tendências Ocultas</MudText>
                            <ul class="mb-0">
                                @foreach (var n in _mapa.TendenciasOcultas)
                                {
                                    <li><strong>@n</strong> — @InterpretacoesNumerologicas.TendenciaOculta(n)</li>
                                }
                            </ul>
                        </MudCardContent></MudCard>
                    </MudItem>
                }

                @if (_mapa.DividasCarmicas.Any())
                {
                    <MudItem xs="12">
                        <MudCard Elevation="1"><MudCardContent>
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Dívidas Cármicas</MudText>
                            <ul class="mb-0">
                                @foreach (var n in _mapa.DividasCarmicas)
                                {
                                    <li><strong>@n</strong> — @InterpretacoesNumerologicas.DividaCarmica(n)</li>
                                }
                            </ul>
                        </MudCardContent></MudCard>
                    </MudItem>
                }

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="1"><MudCardContent>
                        <MudText Typo="Typo.subtitle2">Relação Intervalores — @_mapa.RelacaoIntervalores</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" data-testid="interp-intervalores">@InterpretacoesNumerologicas.RelacaoIntervalores(_mapa.RelacaoIntervalores)</MudText>
                    </MudCardContent></MudCard>
                </MudItem>

            </MudGrid>

        </MudExpansionPanel>
    </MudExpansionPanels>

    <div class="mt-3 mb-5 d-flex gap-2">
        <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{MapaId}/editar")"
                   Variant="Variant.Outlined"
                   Color="Color.Primary">Editar</MudButton>
        <MudButton Href="@($"/api/consulentes/{ConsulenteId}/mapas/{MapaId}/pdf")"
                   Target="_blank"
                   Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                   data-testid="btn-baixar-pdf">Baixar PDF</MudButton>
        <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas")"
                   Variant="Variant.Outlined"
                   Color="Color.Default">Voltar</MudButton>
    </div>
}

@code {
    [Parameter] public int ConsulenteId { get; set; }
    [Parameter] public int MapaId { get; set; }

    private MapaDetalheDto? _mapa;
    private ResultadoPessoalDto? _pessoal;
    private bool _carregando = true;
    private string? _erro;

    protected override async Task OnParametersSetAsync()
    {
        _carregando = true;
        try
        {
            _mapa = await MapasService.ObterAsync(ConsulenteId, MapaId);
            if (_mapa is null)
            {
                _erro = "Mapa não encontrado.";
                return;
            }

            _pessoal = await PessoaisService.ObterAsync(
                _mapa.DataNascimento.Day,
                _mapa.DataNascimento.Month);
        }
        catch
        {
            _erro = "Erro ao carregar o gráfico.";
        }
        finally
        {
            _carregando = false;
        }
    }
}
