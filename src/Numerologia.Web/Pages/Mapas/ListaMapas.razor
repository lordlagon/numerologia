@page "/consulentes/{ConsulenteId:int}/mapas"
@inject IMapasService MapasService
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Mapas Numerológicos</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Mapas Numerológicos</MudText>
    <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/novo")"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add">
        Gerar Mapa
    </MudButton>
</MudStack>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else if (_mapas.Count == 0)
{
    <MudText Color="Color.Secondary">Nenhum mapa gerado ainda.</MudText>
}
else
{
    <MudTable Items="_mapas" Hover="true" Dense="true" Elevation="1">
        <HeaderContent>
            <MudTh>Nome Utilizado</MudTh>
            <MudTh>Data de Nascimento</MudTh>
            <MudTh>Criado em</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nome" data-testid="@($"mapa-{context.Id}")">
                @context.NomeUtilizado
            </MudTd>
            <MudTd DataLabel="Nascimento">@context.DataNascimento.ToString("dd/MM/yyyy")</MudTd>
            <MudTd DataLabel="Criado em">@context.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd Style="text-align:right; white-space:nowrap">
                <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{context.Id}")"
                           Size="Size.Small"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Class="mr-1">
                    Ver Mapa
                </MudButton>
                <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{context.Id}/editar")"
                           Size="Size.Small"
                           Variant="Variant.Outlined"
                           Class="mr-1">
                    Editar
                </MudButton>
                <MudButton Size="Size.Small"
                           Variant="Variant.Outlined"
                           Color="Color.Error"
                           Class="mr-1"
                           OnClick="() => Excluir(context.Id, context.NomeUtilizado)">
                    Excluir
                </MudButton>
                <MudTooltip Text="Em breve">
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Disabled="true">
                        Pirâmides
                    </MudButton>
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudButton Href="/consulentes"
           Variant="Variant.Outlined"
           Class="mt-4"
           StartIcon="@Icons.Material.Filled.ArrowBack">
    Voltar
</MudButton>

@code {
    [Parameter] public int ConsulenteId { get; set; }

    private List<MapaResumoDto> _mapas = [];
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _mapas = await MapasService.ListarAsync(ConsulenteId);
        }
        catch
        {
            Snackbar.Add("Erro ao carregar mapas.", Severity.Error);
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Excluir(int mapaId, string nomeUtilizado)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Confirmar exclusão",
            $"Excluir o mapa de \"{nomeUtilizado}\"? Esta ação não pode ser desfeita.",
            yesText: "Excluir",
            cancelText: "Cancelar");

        if (result != true) return;

        try
        {
            await MapasService.RemoverAsync(ConsulenteId, mapaId);
            _mapas = await MapasService.ListarAsync(ConsulenteId);
            Snackbar.Add("Mapa excluído.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Erro ao excluir mapa.", Severity.Error);
        }
    }
}
