@page "/consulentes/{ConsulenteId:int}/mapas"
@inject IMapasService MapasService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Mapas Numerológicos</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5">Mapas Numerológicos</MudText>
    <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/novo")"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add">
        Gerar Mapa
    </MudButton>
</div>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" Class="mb-2" />
    <MudText>Carregando...</MudText>
}
else if (_mapas.Count == 0)
{
    <MudText Color="Color.Secondary">Nenhum mapa gerado ainda.</MudText>
}
else
{
    <MudTable Items="@_mapas" Hover="true" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh>Nome Utilizado</MudTh>
            <MudTh>Nascimento</MudTh>
            <MudTh>Criado em</MudTh>
            <MudTh Style="text-align:right"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nome Utilizado" data-testid="@($"mapa-{context.Id}")">@context.NomeUtilizado</MudTd>
            <MudTd DataLabel="Nascimento">@context.DataNascimento.ToString("dd/MM/yyyy")</MudTd>
            <MudTd DataLabel="Criado em">@context.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd Style="text-align:right">
                <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{context.Id}")"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small">Ver Mapa</MudButton>
                <MudButton Href="@($"/consulentes/{ConsulenteId}/mapas/{context.Id}/editar")"
                           Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Small"
                           Class="ml-1">Editar</MudButton>
                @{var mId = context.Id; var mNome = context.NomeUtilizado;}
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           Size="Size.Small"
                           Class="ml-1"
                           OnClick="@(async () => await Excluir(mId, mNome))">Excluir</MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Small"
                           Class="ml-1"
                           Disabled="true"
                           title="Em breve">Pirâmides</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@if (_erro is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-3">@_erro</MudAlert>
}

<MudButton Href="/consulentes"
           Variant="Variant.Outlined"
           Color="Color.Default"
           Class="mt-3">Voltar</MudButton>

@code {
    [Parameter] public int ConsulenteId { get; set; }

    private List<MapaResumoDto> _mapas = [];
    private bool _carregando = true;
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _mapas = await MapasService.ListarAsync(ConsulenteId);
        }
        catch
        {
            _erro = "Erro ao carregar mapas.";
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Excluir(int mapaId, string nomeUtilizado)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm",
            $"Excluir o mapa de \"{nomeUtilizado}\"? Esta ação não pode ser desfeita.");

        if (!confirmado) return;

        try
        {
            await MapasService.RemoverAsync(ConsulenteId, mapaId);
            _mapas = await MapasService.ListarAsync(ConsulenteId);
        }
        catch
        {
            _erro = "Erro ao excluir mapa.";
        }
    }
}
