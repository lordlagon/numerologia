@page "/perfil"
@inject IPerfilService PerfilService
@inject PerfilState PerfilState

<PageTitle>Perfil</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Perfil</MudText>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" />
    <MudText>Carregando...</MudText>
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:480px">
        <MudTextField Value="@_perfil!.Email"
                      Label="E-mail"
                      ReadOnly="true"
                      Class="mb-3" />

        <MudTextField Value="@_perfil.Nome"
                      Label="Nome (Google)"
                      ReadOnly="true"
                      Class="mb-3" />

        <form @onsubmit="SalvarAsync" @onsubmit:preventDefault>
            <MudTextField @bind-Value="_nomeExibicao"
                          Label="Nome de Exibição"
                          HelperText="Usado na capa do PDF. Se vazio, será usado o nome do Google."
                          Placeholder="Nome para a capa do PDF (opcional)"
                          Class="mb-3"
                          data-testid="nomeExibicao" />

            @if (!string.IsNullOrEmpty(_erro))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_erro</MudAlert>
            }

            @if (_salvoComSucesso)
            {
                <MudAlert Severity="Severity.Success" Class="mb-3">Perfil atualizado com sucesso.</MudAlert>
            }

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_salvando">
                @(_salvando ? "Salvando..." : "Salvar")
            </MudButton>
        </form>
    </MudPaper>
}

@code {
    private PerfilDto? _perfil;
    private string? _nomeExibicao;
    private bool _carregando = true;
    private bool _salvando;
    private bool _salvoComSucesso;
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        _perfil = await PerfilService.ObterAsync();
        _nomeExibicao = _perfil.NomeExibicao;
        _carregando = false;
    }

    private async Task SalvarAsync()
    {
        _erro = null;
        _salvoComSucesso = false;

        var nomeParaSalvar = string.IsNullOrWhiteSpace(_nomeExibicao) ? null : _nomeExibicao.Trim();

        _salvando = true;
        try
        {
            _perfil = await PerfilService.AtualizarAsync(new SalvarPerfilDto(nomeParaSalvar));
            _nomeExibicao = _perfil.NomeExibicao;
            _salvoComSucesso = true;
            PerfilState.Atualizar(_perfil.NomeExibicao);
        }
        catch
        {
            _erro = "Erro ao salvar. Tente novamente.";
        }
        finally
        {
            _salvando = false;
        }
    }
}
