@page "/dashboard"
@inject IDashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Dashboard</MudText>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" />
    <MudText>Carregando...</MudText>
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudCard Elevation="3">
                <MudCardContent Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h3" Class="mt-2" data-testid="total-consulentes">@_dados!.TotalConsulentes</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total de Consulentes</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Últimos Mapas Criados</MudText>

    @if (_dados!.UltimosMapas.Count == 0)
    {
        <MudText Color="Color.Secondary">Nenhum mapa gerado ainda.</MudText>
    }
    else
    {
        <MudPaper Elevation="1">
            <MudList T="string">
                @foreach (var m in _dados.UltimosMapas)
                {
                    <MudListItem Href="@($"/consulentes/{m.ConsulenteId}/mapas/{m.MapaId}")"
                                 Icon="@Icons.Material.Filled.Description">
                        <MudText>
                            <strong>@m.NomeConsulente</strong>
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @m.NomeUtilizado — @m.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </MudText>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        </MudPaper>
    }
}

@code {
    private DashboardDto? _dados;
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        _dados = await DashboardService.ObterAsync();
        _carregando = false;
    }
}
