@page "/dashboard"
@inject IDashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2">
                <MudCardContent Class="text-center">
                    <MudText Typo="Typo.h2" Color="Color.Primary">@_dados!.TotalConsulentes</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">Consulentes</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Últimos Mapas Criados</MudText>

    @if (_dados!.UltimosMapas.Count == 0)
    {
        <MudText Color="Color.Secondary">Nenhum mapa gerado ainda.</MudText>
    }
    else
    {
        <MudList T="UltimoMapaDto" Dense="true">
            @foreach (var m in _dados.UltimosMapas)
            {
                <MudListItem T="UltimoMapaDto" Href="@($"/consulentes/{m.ConsulenteId}/mapas/{m.MapaId}")">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">@m.NomeConsulente</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@m.NomeUtilizado</MudText>
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @m.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </MudText>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
}

@code {
    private DashboardDto? _dados;
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        _dados = await DashboardService.ObterAsync();
        _carregando = false;
    }
}
