@page "/consulentes"
@inject IConsulentesService ConsulentesService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Consulentes</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5">Consulentes</MudText>
    <MudButton Href="/consulentes/novo"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add">
        Novo Consulente
    </MudButton>
</div>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" Class="mb-2" />
    <MudText>Carregando...</MudText>
}
else
{
    <MudTextField @bind-Value="_busca"
                  Placeholder="Buscar por nome..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true"
                  Class="mb-4"
                  data-testid="busca-nome" />

    @if (_consultentsFiltrados.Count == 0 && _consulentes.Count > 0)
    {
        <MudText Color="Color.Secondary">Nenhum consulente encontrado para "@_busca".</MudText>
    }
    else if (_consulentes.Count == 0)
    {
        <MudText>Nenhum consulente cadastrado ainda.</MudText>
    }
    else
    {
        <MudTable Items="@_consultentsFiltrados" Hover="true" Elevation="2" Dense="true">
            <HeaderContent>
                <MudTh>Nome</MudTh>
                <MudTh>Nascimento</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Telefone</MudTh>
                <MudTh Style="text-align:right"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nome">@context.NomeCompleto</MudTd>
                <MudTd DataLabel="Nascimento">@context.DataNascimento.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
                <MudTd DataLabel="Telefone">@(context.Telefone ?? "—")</MudTd>
                <MudTd Style="text-align:right">
                    <MudButton Href="@($"/consulentes/{context.Id}/mapas")"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               aria-label="Mapas">Mapas</MudButton>
                    <MudButton Href="@($"/consulentes/{context.Id}/editar")"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Class="ml-1">Editar</MudButton>
                    @{var cId = context.Id;}
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Size="Size.Small"
                               Class="ml-1"
                               OnClick="@(async () => await Excluir(cId))"
                               data-testid="@($"excluir-{context.Id}")">Excluir</MudButton>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4">Nenhum consulente encontrado.</MudText>
            </NoRecordsContent>
        </MudTable>
    }
}

@if (_erro is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-3">@_erro</MudAlert>
}

@code {
    private List<ConsulenteDto> _consulentes = [];
    private bool _carregando = true;
    private string? _erro;
    private string _busca = "";

    private List<ConsulenteDto> _consultentsFiltrados =>
        string.IsNullOrWhiteSpace(_busca)
            ? _consulentes
            : _consulentes
                .Where(c => c.NomeCompleto.Contains(_busca, StringComparison.OrdinalIgnoreCase))
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _consulentes = await ConsulentesService.ListarAsync();
        }
        catch
        {
            _erro = "Erro ao carregar consulentes.";
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Excluir(int id)
    {
        var confirmar = await JS.InvokeAsync<bool>("confirm",
            "Excluir este consulente? Todos os seus mapas também serão excluídos.");
        if (!confirmar) return;

        try
        {
            await ConsulentesService.RemoverAsync(id);
            _consulentes = _consulentes.Where(c => c.Id != id).ToList();
        }
        catch
        {
            _erro = "Erro ao excluir consulente.";
        }
    }
}
