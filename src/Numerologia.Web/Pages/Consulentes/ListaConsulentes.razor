@page "/consulentes"
@inject IConsulentesService ConsulentesService
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Consulentes</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Consulentes</MudText>
    <MudButton Href="/consulentes/novo"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd">
        Novo Consulente
    </MudButton>
</MudStack>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else
{
    <MudTextField @bind-Value="_busca"
                  Placeholder="Buscar por nome..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true"
                  Immediate="true"
                  Class="mb-4"
                  UserAttributes='@(new Dictionary<string, object?> { ["data-testid"] = "busca-nome" })' />

    @if (_consultentsFiltrados.Count == 0 && _consulentes.Count > 0)
    {
        <MudText Color="Color.Secondary">Nenhum consulente encontrado para "@_busca".</MudText>
    }
    else if (_consulentes.Count == 0)
    {
        <MudText>Nenhum consulente cadastrado ainda.</MudText>
    }
    else
    {
        <MudTable Items="_consultentsFiltrados" Hover="true" Dense="true" Elevation="1">
            <HeaderContent>
                <MudTh>Nome</MudTh>
                <MudTh>Data de Nascimento</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Telefone</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nome">@context.NomeCompleto</MudTd>
                <MudTd DataLabel="Nascimento">@context.DataNascimento.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
                <MudTd DataLabel="Telefone">@(context.Telefone ?? "—")</MudTd>
                <MudTd Style="text-align:right; white-space:nowrap">
                    <MudTooltip Text="Mapas">
                        <MudIconButton Icon="@Icons.Material.Filled.Description"
                                       Size="Size.Small"
                                       Href="@($"/consulentes/{context.Id}/mapas")"
                                       aria-label="Mapas" />
                    </MudTooltip>
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Href="@($"/consulentes/{context.Id}/editar")" />
                    </MudTooltip>
                    <MudTooltip Text="Excluir">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       data-testid="@($"excluir-{context.Id}")"
                                       OnClick="() => Excluir(context.Id)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Nenhum consulente cadastrado ainda.</MudText>
            </NoRecordsContent>
        </MudTable>
    }
}

@code {
    private List<ConsulenteDto> _consulentes = [];
    private bool _carregando = true;
    private string _busca = "";

    private List<ConsulenteDto> _consultentsFiltrados =>
        string.IsNullOrWhiteSpace(_busca)
            ? _consulentes
            : _consulentes
                .Where(c => c.NomeCompleto.Contains(_busca, StringComparison.OrdinalIgnoreCase))
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _consulentes = await ConsulentesService.ListarAsync();
        }
        catch
        {
            Snackbar.Add("Erro ao carregar consulentes.", Severity.Error);
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task Excluir(int id)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Confirmar exclusão",
            "Excluir este consulente? Todos os seus mapas também serão excluídos.",
            yesText: "Excluir",
            cancelText: "Cancelar");

        if (result != true) return;

        try
        {
            await ConsulentesService.RemoverAsync(id);
            _consulentes = _consulentes.Where(c => c.Id != id).ToList();
            Snackbar.Add("Consulente excluído.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Erro ao excluir consulente.", Severity.Error);
        }
    }
}
