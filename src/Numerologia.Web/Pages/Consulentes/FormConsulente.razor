@page "/consulentes/novo"
@page "/consulentes/{Id:int}/editar"
@using System.ComponentModel.DataAnnotations
@inject IConsulentesService ConsulentesService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_id is null ? "Novo Consulente" : "Editar Consulente")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@(_id is null ? "Novo Consulente" : "Editar Consulente")</MudText>

@if (_carregando)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" aria-label="Carregando" />
}
else
{
    <MudPaper Elevation="1" Class="pa-6" Style="max-width:520px">
        <EditForm Model="_form" OnValidSubmit="Salvar">
            <DataAnnotationsValidator />

            <MudStack Spacing="4">
                <MudTextField @bind-Value="_form.NomeCompleto"
                              Label="Nome completo"
                              Required="true"
                              RequiredError="Nome é obrigatório"
                              For="() => _form.NomeCompleto"
                              data-testid="nome" />

                <MudDatePicker @bind-Date="_dataNascimentoDt"
                               Label="Data de nascimento"
                               Required="true"
                               DateFormat="dd/MM/yyyy"
                               data-testid="data-nascimento" />

                <MudTextField @bind-Value="_form.Email"
                              Label="Email"
                              InputType="InputType.Email"
                              data-testid="email" />

                <MudTextField @bind-Value="_form.Telefone"
                              Label="Telefone"
                              data-testid="telefone" />

                <MudStack Row="true" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_salvando">
                        @(_salvando ? "Salvando..." : "Salvar")
                    </MudButton>
                    <MudButton Href="/consulentes"
                               Variant="Variant.Outlined">
                        Cancelar
                    </MudButton>
                </MudStack>
            </MudStack>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public int? Id { get; set; }

    private int? _id;
    private FormModel _form = new();
    private bool _carregando = true;
    private bool _salvando;

    private DateTime? _dataNascimentoDt
    {
        get => _form.DataNascimento == default ? null : _form.DataNascimento.ToDateTime(TimeOnly.MinValue);
        set => _form.DataNascimento = value.HasValue ? DateOnly.FromDateTime(value.Value) : DateOnly.FromDateTime(DateTime.Today);
    }

    protected override async Task OnParametersSetAsync()
    {
        _id = Id;
        _carregando = true;

        if (_id is not null)
        {
            try
            {
                var consulente = await ConsulentesService.ObterAsync(_id.Value);
                if (consulente is not null)
                {
                    _form = new FormModel
                    {
                        NomeCompleto   = consulente.NomeCompleto,
                        DataNascimento = consulente.DataNascimento,
                        Email          = consulente.Email,
                        Telefone       = consulente.Telefone,
                    };
                }
            }
            catch
            {
                Snackbar.Add("Erro ao carregar consulente.", Severity.Error);
            }
        }

        _carregando = false;
    }

    private async Task Salvar()
    {
        _salvando = true;

        try
        {
            var dto = new SalvarConsulenteDto(
                _form.NomeCompleto!,
                _form.DataNascimento.ToString("yyyy-MM-dd"),
                _form.Email,
                _form.Telefone);

            if (_id is null)
                await ConsulentesService.CriarAsync(dto);
            else
                await ConsulentesService.AtualizarAsync(_id.Value, dto);

            Nav.NavigateTo("/consulentes");
        }
        catch
        {
            Snackbar.Add("Erro ao salvar consulente.", Severity.Error);
            _salvando = false;
        }
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Nome é obrigatório")]
        public string? NomeCompleto { get; set; }

        public DateOnly DataNascimento { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        public string? Email { get; set; }

        public string? Telefone { get; set; }
    }
}
