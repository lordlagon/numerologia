@page "/consulentes/novo"
@page "/consulentes/{Id:int}/editar"
@using System.ComponentModel.DataAnnotations
@inject IConsulentesService ConsulentesService
@inject NavigationManager Nav

<PageTitle>@(_id is null ? "Novo Consulente" : "Editar Consulente")</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">@(_id is null ? "Novo Consulente" : "Editar Consulente")</MudText>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" />
    <MudText>Carregando...</MudText>
}
else
{
    <MudPaper Elevation="2" Class="pa-4" Style="max-width:540px">
        <EditForm Model="_form" OnValidSubmit="Salvar">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_form.NomeCompleto"
                          Label="Nome completo *"
                          For="() => _form.NomeCompleto"
                          Immediate="true"
                          Class="mb-3"
                          data-testid="nome" />

            <MudTextField @bind-Value="_dataNascimentoStr"
                          Label="Data de nascimento *"
                          InputType="InputType.Date"
                          Class="mb-3"
                          data-testid="data-nascimento" />

            <MudTextField @bind-Value="_form.Email"
                          Label="Email"
                          Class="mb-3"
                          data-testid="email" />

            <MudTextField @bind-Value="_form.Telefone"
                          Label="Telefone"
                          Class="mb-3"
                          data-testid="telefone" />

            @if (_erro is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_erro</MudAlert>
            }

            <div class="d-flex gap-2">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_salvando">
                    @(_salvando ? "Salvando..." : "Salvar")
                </MudButton>
                <MudButton Href="/consulentes"
                           Variant="Variant.Outlined"
                           Color="Color.Default">Cancelar</MudButton>
            </div>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public int? Id { get; set; }

    private int? _id;
    private FormModel _form = new();
    private string _dataNascimentoStr = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    private bool _carregando = true;
    private bool _salvando;
    private string? _erro;

    protected override async Task OnParametersSetAsync()
    {
        _id = Id;
        _carregando = true;

        if (_id is not null)
        {
            try
            {
                var consulente = await ConsulentesService.ObterAsync(_id.Value);
                if (consulente is not null)
                {
                    _form = new FormModel
                    {
                        NomeCompleto = consulente.NomeCompleto,
                        Email        = consulente.Email,
                        Telefone     = consulente.Telefone,
                    };
                    _dataNascimentoStr = consulente.DataNascimento.ToString("yyyy-MM-dd");
                }
            }
            catch
            {
                _erro = "Erro ao carregar consulente.";
            }
        }

        _carregando = false;
    }

    private async Task Salvar()
    {
        _salvando = true;
        _erro = null;

        try
        {
            var dto = new SalvarConsulenteDto(
                _form.NomeCompleto!,
                _dataNascimentoStr,
                _form.Email,
                _form.Telefone);

            if (_id is null)
                await ConsulentesService.CriarAsync(dto);
            else
                await ConsulentesService.AtualizarAsync(_id.Value, dto);

            Nav.NavigateTo("/consulentes");
        }
        catch
        {
            _erro = "Erro ao salvar consulente.";
            _salvando = false;
        }
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Nome é obrigatório")]
        public string? NomeCompleto { get; set; }

        public string? Email { get; set; }

        public string? Telefone { get; set; }
    }
}
