@page "/"
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Numerologia Cabalística</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_usuario is null)
{
    <MudText Typo="Typo.h4" Class="mb-3">Numerologia Cabalística</MudText>
    <MudText Class="mb-4">Faça login para acessar seu mapa numerológico.</MudText>
    <MudButton Href="/auth/login"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Login">
        Entrar com Google
    </MudButton>
}
else
{
    Nav.NavigateTo("/dashboard", replace: true);
}

@code {
    private UsuarioInfo? _usuario;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
        _loading = false;
    }
}
