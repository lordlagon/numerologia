@page "/"
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Numerologia Cabalística</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (_usuario is null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
        <MudText Typo="Typo.h3" Class="mb-2">Numerologia Cabalística</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8">
            Faça login para acessar seu mapa numerológico.
        </MudText>
        <MudButton Href="/auth/login"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   StartIcon="@Icons.Custom.Brands.Google">
            Entrar com Google
        </MudButton>
    </MudContainer>
}

@code {
    private UsuarioInfo? _usuario;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _usuario = await AuthService.GetCurrentUserAsync();
        _loading = false;
        if (_usuario is not null)
            Nav.NavigateTo("/dashboard", replace: true);
    }
}
