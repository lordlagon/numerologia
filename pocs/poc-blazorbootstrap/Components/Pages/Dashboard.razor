@page "/"
@rendermode InteractiveServer

<PageTitle>Dashboard — Blazor Bootstrap POC</PageTitle>

<h5 class="mb-4">Dashboard</h5>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-people-fill fs-1 text-success"></i>
                <h2 class="mt-2">@MockDataService.Consulentes.Count</h2>
                <p class="text-muted mb-0">Total de Consulentes</p>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-file-earmark-text-fill fs-1 text-success"></i>
                <h2 class="mt-2">@MockDataService.Consulentes.Sum(c => c.TotalMapas)</h2>
                <p class="text-muted mb-0">Total de Mapas</p>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-4">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <i class="bi bi-graph-up-arrow fs-1 text-success"></i>
                <h2 class="mt-2">@MockDataService.Consulentes.Count(c => c.TotalMapas > 0)</h2>
                <p class="text-muted mb-0">Com Mapas Gerados</p>
            </div>
        </div>
    </div>
</div>

<h6 class="mb-3">Últimos Mapas</h6>
<div class="card shadow-sm">
    <ul class="list-group list-group-flush">
        @foreach (var c in MockDataService.Consulentes.Where(x => x.TotalMapas > 0))
        {
            <li class="list-group-item d-flex align-items-center gap-3">
                <i class="bi bi-person-circle fs-4 text-success"></i>
                <div class="flex-grow-1">
                    <strong>@c.Nome</strong>
                    <div class="text-muted small">@c.DataNascimento.ToString("dd/MM/yyyy")</div>
                </div>
                <Badge Color="BadgeColor.Success">@c.TotalMapas mapa(s)</Badge>
            </li>
        }
    </ul>
</div>
